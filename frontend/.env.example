# ──────────────────────────────────────────────────────────────────────────────
# ADOS Frontend – Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and replace all placeholder values.
# This file IS committed to source control (no real credentials here).
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (main project) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend services ──────────────────────────────────────────────────────────
# Main FastAPI backend (adsurv, targeting-intel, etc.)
VITE_API_BASE_URL=http://localhost:8000

# Auth service (login / signup)
VITE_AUTH_API_URL=http://localhost:5003

# GenAI / Command-Center / ChatInput service
VITE_GENAI_API_URL=http://127.0.0.1:5002

# Image-generation service (GenerateAdPopup)
VITE_IMAGE_GEN_API_URL=http://localhost:5002

# Image-generation REST API (imageGeneration.ts)
VITE_IMAGE_GEN_REST_URL=http://localhost:5006/api

# AutoCreate / campaign service
VITE_AUTOCREATE_API_URL=http://localhost:5050

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_TITLE=ADOS
